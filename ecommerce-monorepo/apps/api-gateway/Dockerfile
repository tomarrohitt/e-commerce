FROM node@sha256:24dc26ef1e3c3690f27ebc4136c9c186c3133b25563ae4d7f0692e4d1fe5db0e AS base

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN apt-get update -y && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*
RUN corepack enable && corepack prepare pnpm@11.3.0 --activate

FROM base AS builder
WORKDIR /app

# Copy monorepo configurations and source
COPY . .
RUN pnpm install --no-frozen-lockfile

# Build the shared local package AND the api-gateway app
RUN pnpm --filter @ecommerce/common build
# Note: Replace 'api-gateway' with the actual "name" field from apps/api-gateway/package.json if it differs
RUN pnpm --filter api-gateway build 

# Use pnpm deploy to isolate the app and prune out devDependencies automatically
RUN pnpm --filter api-gateway --prod deploy /prod/api-gateway

FROM node@sha256:242549cd46785b480c832479a730f4f2a20865d61ea2e404fdb2a5c3d3b73ecf AS runner

ENV NODE_ENV=production
WORKDIR /prod/api-gateway

RUN apt-get update -y && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

# Copy the completely isolated production package generated by pnpm deploy
COPY --from=builder /prod/api-gateway .

EXPOSE 4000
CMD ["node", "dist/index.js"]
